---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import Giscus from "@/components/Giscus.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE, GISCUS } from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

const { Content, headings } = await render(post);
const tocSections: Array<
  (typeof headings)[number] & { children: Array<(typeof headings)[number]> }
> = [];
const tocLinkClass =
  "toc-link block wrap-break-word text-foreground/80 decoration-dashed underline-offset-4 transition-colors hover:text-accent hover:underline";
let currentSection: (typeof tocSections)[number] | undefined;

for (const heading of headings) {
  if (heading.depth === 2) {
    currentSection = { ...heading, children: [] };
    tocSections.push(currentSection);
  } else if (heading.depth === 3) {
    currentSection?.children.push(heading);
  }
}

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote or local ogImage is set
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}

// Resolve OG image URL (or fall back to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length ? allPosts[currentPostIndex + 1] : null;
---

<Layout {...layoutProps}>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    <div class="min-w-0">
      <h1
        transition:name={slugifyStr(title.replaceAll(".", "-"))}
        class="mt-2 mb-1 inline-block text-2xl font-bold text-accent sm:text-3xl"
      >
        {title}
      </h1>
      <div class="my-2 flex items-center gap-2">
        <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
        <span
          aria-hidden="true"
          class:list={[
            "max-sm:hidden",
            { hidden: !SITE.editPost.enabled || hideEditPost },
          ]}>|</span
        >
        <EditPost {hideEditPost} {post} class="max-sm:hidden" />
      </div>
      <article
        id="article"
        class="app-prose post-prose mt-8 w-full max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
      >
        <Content />
      </article>

      <hr class="my-8 border-dashed" />

      <EditPost class="sm:hidden" {hideEditPost} {post} />

      <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
        {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
      </ul>

      <BackToTopButton />

      <ShareLinks />

      <hr class="my-6 border-dashed" />

      {GISCUS.enabled && <Giscus />}

      {GISCUS.enabled && <hr class="my-6 border-dashed" />}

      <!-- Previous/Next Post Buttons -->
      <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {
          prevPost && (
            <a
              href={getPath(prevPost.id, prevPost.filePath)}
              class="flex w-full gap-1 hover:opacity-75"
            >
              <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
              <div>
                <span>Previous Post</span>
                <div class="text-sm text-accent/85">{prevPost.title}</div>
              </div>
            </a>
          )
        }
        {
          nextPost && (
            <a
              href={getPath(nextPost.id, nextPost.filePath)}
              class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
            >
              <div>
                <span>Next Post</span>
                <div class="text-sm text-accent/85">{nextPost.title}</div>
              </div>
              <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
            </a>
          )
        }
      </div>
    </div>

    {
      tocSections.length > 0 && (
        <aside
          class="post-toc hidden border-s border-border ps-5 xl:block"
          data-pagefind-ignore
        >
          <h2 class="mb-3 text-sm font-bold text-foreground/80">
            {SITE.tocLabel}
          </h2>
          <nav aria-label={SITE.tocLabel}>
            <ul class="list-disc space-y-2 ps-4 text-sm leading-snug marker:text-accent">
              {tocSections.map(({ slug: sectionSlug, text, children }) => (
                <li>
                  <a
                    data-toc-link
                    data-toc-section={sectionSlug}
                    href={`#${sectionSlug}`}
                    class={tocLinkClass}
                  >
                    {text}
                  </a>
                  {children.length > 0 && (
                    <ul
                      data-toc-children={sectionSlug}
                      class="mt-2 list-disc space-y-2 ps-4 marker:text-accent"
                      hidden
                    >
                      {children.map(({ slug, text }) => (
                        <li>
                          <a
                            data-toc-link
                            data-toc-parent={sectionSlug}
                            href={`#${slug}`}
                            class={tocLinkClass}
                          >
                            {text}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )
    }
  </main>
  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when the user scrolls */
  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  /** Attaches links to headings in the document
   *  so users can easily share links to specific sections */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("#article h2, #article h3")
    );
    for (const heading of headings) {
      if (!heading.id || heading.querySelector(".heading-link")) continue;

      const link = document.createElement("a");
      link.className =
        "heading-link me-2 no-underline opacity-75 transition-opacity hover:opacity-100 focus:opacity-100";
      link.href = "#" + heading.id;
      link.ariaLabel = "Link to this section";

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.prepend(link);
    }
  }
  addHeadingLinks();

  /** Highlights the table of contents item
   *  matching the section currently near the top of the viewport. */
  function highlightActiveTocItem() {
    const tocLinks = Array.from(document.querySelectorAll("[data-toc-link]"));
    if (!tocLinks.length) return;

    function getLinkId(link) {
      const rawHash = link.getAttribute("href")?.slice(1);
      return rawHash ? decodeURIComponent(rawHash) : "";
    }

    // Precompute everything once: section -> {sectionLink, childrenList},
    // and the ordered heading list scroll uses.
    const sectionMap = new Map();
    const headings = [];

    for (const link of tocLinks) {
      const id = getLinkId(link);
      if (!id) continue;

      const heading = document.getElementById(id);
      const section =
        link.getAttribute("data-toc-section") ||
        link.getAttribute("data-toc-parent") ||
        "";
      if (!heading || !section) continue;

      headings.push({ heading, link, section });

      if (link.hasAttribute("data-toc-section")) {
        const childrenList =
          link.parentElement?.querySelector("[data-toc-children]") ?? null;
        sectionMap.set(section, { sectionLink: link, childrenList });
      }
    }

    if (!headings.length) return;

    const controller = new AbortController();
    const { signal } = controller;

    let prevSection = "";
    let prevActiveLink = null;

    function setActiveLink() {
      const offset = 140;
      let activeHeading = null;
      for (let index = headings.length - 1; index >= 0; index -= 1) {
        if (headings[index].heading.getBoundingClientRect().top <= offset) {
          activeHeading = headings[index];
          break;
        }
      }

      const activeSection = activeHeading?.section ?? "";

      if (activeSection !== prevSection) {
        const prev = sectionMap.get(prevSection);
        if (prev) {
          prev.sectionLink.removeAttribute("data-active-section");
          prev.childrenList?.toggleAttribute("hidden", true);
        }
        const next = sectionMap.get(activeSection);
        if (next) {
          next.sectionLink.setAttribute("data-active-section", "");
          next.childrenList?.toggleAttribute("hidden", false);
        }
        prevSection = activeSection;
      }

      const activeLink = activeHeading?.link ?? null;
      if (activeLink !== prevActiveLink) {
        prevActiveLink?.removeAttribute("aria-current");
        activeLink?.setAttribute("aria-current", "location");
        activeLink?.scrollIntoView({ block: "nearest", inline: "nearest" });
        prevActiveLink = activeLink;
      }
    }

    let ticking = false;
    function requestActiveLinkUpdate() {
      if (ticking) return;

      ticking = true;
      window.requestAnimationFrame(() => {
        setActiveLink();
        ticking = false;
      });
    }

    setActiveLink();
    document.addEventListener("scroll", requestActiveLinkUpdate, {
      passive: true,
      signal,
    });
    window.addEventListener("resize", requestActiveLinkUpdate, { signal });
    document.addEventListener("astro:before-swap", () => controller.abort(), {
      once: true,
      signal,
    });
  }
  highlightActiveTocItem();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      // Check if --file-name-offset custom property exists
      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      // Determine the top positioning class
      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap code block with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that the copy succeeded
      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  /* Go to page start after page swap */
  document.addEventListener(
    "astro:after-swap",
    () => {
      window.scrollTo({ left: 0, top: 0, behavior: "instant" });
    },
    { once: true }
  );
</script>
